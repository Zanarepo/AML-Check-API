# Supabase Project Credentials
# You can find these in your Supabase Dashboard -> Project Settings -> API

# The URL of your Supabase project (e.g., https://xyzcompany.supabase.co)
SUPABASE_URL="https://your-project-url.supabase.co"

# The Service Role Key (Needed for the backend to bypass RLS when validating API keys)
# VERY IMPORTANT: Never expose this to the frontend/browser!
SUPABASE_SERVICE_KEY="eyJhb...your_service_role_key_here..."

# Optional: The public anon key (if your frontend dashboard needs it)
SUPABASE_ANON_KEY="eyJhb...your_anon_key_here..."

# Application Settings
ENVIRONMENT="development" # or "production"

# A secure random string used for hashing/salting the customer's API keys
# You can generate one via terminal: python -c "import secrets; print(secrets.token_hex(32))"
API_AUTH_SECRET="your-super-secret-auth-string-here"
